rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chat messages
    match /messages/{messageId} {
      // Anyone can read (for future direct Firestore reads)
      allow read: if true;
      // Only server-side (Admin SDK bypasses rules) — block all client writes
      allow write: if false;
    }

    // Reactions (not persisted, but rule kept for safety)
    match /reactions/{reactionId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
