rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Chat messages rules
    match /messages/{messageId} {
      // Anyone can read messages
      allow read: if true;
      // Only authenticated users can write messages
      // Message must have text and user uid matching the auth uid
      allow create: if request.auth != null 
                    && request.resource.data.text is string
                    && request.resource.data.text.trim().size() > 0
                    && request.resource.data.uid == request.auth.uid;
      // No updates or deletes allowed
      allow update, delete: if false;
    }

    // Reactions rules
    match /reactions/{reactionId} {
      // Anyone can read reactions
      allow read: if true;
      // Only authenticated users can write reactions
      allow create: if request.auth != null
                    && request.resource.data.emoji is string
                    && request.resource.data.uid == request.auth.uid;
      // No updates or deletes allowed
      allow update, delete: if false;
    }
  }
}
